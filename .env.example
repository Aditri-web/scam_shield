# ── LLM / Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Google ADK (optional — for ADK-wrapped agents) ───────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=false

# ── Guardian defaults ─────────────────────────────────────────────────────────
GUARDIAN_DEFAULT_CONTACT=+1-555-0100

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Notification (production) ─────────────────────────────────────────────────
# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+15550000000

# SendGrid (email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourcompany.com

# ── SIEM / Logging ────────────────────────────────────────────────────────────
SIEM_WEBHOOK_URL=https://your-siem.example.com/ingest
SIEM_API_KEY=your_siem_key

# ── Webhook ingestion ─────────────────────────────────────────────────────────
WEBHOOK_SECRET=your_hmac_secret_here
